# Vite env (build-time)
# Set your reCAPTCHA v3 site key here (not secret)
VITE_RECAPTCHA_SITE_KEY=
# Optional: local Functions origin used for write requests in dev
VITE_LOCAL_API_ORIGIN=http://127.0.0.1:8788
# Optional: production/preview origin used only for GET/HEAD /api requests in dev
# Example: VITE_READONLY_API_ORIGIN=https://your-production-domain.example
VITE_READONLY_API_ORIGIN=https://tikring.graphica-produce.com/
